    "@preact/preset-vite": "^2.10.0",
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.5.14",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.6",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
