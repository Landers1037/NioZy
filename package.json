{
  "name": "niozy",
  "version": "2.0.10",
  "description": "NioZy — Terminal workbench with built-in AI copilot",
  "author": {
    "name": "Lander1037",
    "email": "mail@renj.io"
  },
  "homepage": "https://github.com/Landers1037/NioZy",
  "repository": {
    "type": "git",
    "url": "https://github.com/Landers1037/NioZy.git"
  },
  "main": "out/main/index.mjs",
  "type": "module",
  "workspaces": [],
  "scripts": {
    "prestart": "npm run generate:icon && npm run vendor:drawing && npm run vendor:oh-my-posh",
    "start": "electron-vite dev",
    "dev": "electron-vite dev",
    "generate:icon": "node scripts/generate-icon.mjs",
    "vendor:excalidraw-fonts": "node scripts/vendor-excalidraw-fonts.mjs",
    "vendor:drawio": "node scripts/vendor-drawio.mjs",
    "vendor:drawing": "npm run vendor:excalidraw-fonts && npm run vendor:drawio",
    "vendor:oh-my-posh": "node scripts/vendor-oh-my-posh.mjs",
    "prebuild": "npm run generate:icon && npm run vendor:drawing && npm run vendor:oh-my-posh",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "analyze:asar": "node scripts/analyze-asar.mjs"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@js-preview/docx": "^1.6.4",
    "@js-preview/excel": "^1.7.14",
